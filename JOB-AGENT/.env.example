# Slack webhook URL for receiving job run notifications
# Get yours at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Firecrawl API key for JS-rendered page scraping (fallback when API scraping fails)
# Get yours at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx

# CAPTCHA solving (optional — only needed if you keep the Playwright fallback)
# Provider: currently only "2captcha" is supported
CAPTCHA_PROVIDER=2captcha
CAPTCHA_API_KEY=your_2captcha_api_key

# Manual CAPTCHA solve mode for WellFound.com (optional)
# Set to "1" to open a headed browser and solve CAPTCHA manually when detected
# Only relevant if you have Playwright installed as a fallback
WELLFOUND_MANUAL_SOLVE=0